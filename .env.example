# ========================================
# Gemini API Configuration
# ========================================
# Get your key from: https://aistudio.google.com/app/apikey
# Free tier: 60 requests/minute, 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# Database Configuration (Neon PostgreSQL)
# ========================================
# Get from: https://neon.tech (Free tier: 0.5 GB)
# Format: postgresql://user:password@host/database
DATABASE_URL=postgresql://user:password@host/database

# ========================================
# Google OAuth Configuration
# ========================================
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URI: https://your-app.railway.app/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/callback

# ========================================
# Session Secret
# ========================================
# Generate a random string (at least 32 characters)
# You can use: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your-random-secret-key-change-in-production

# ========================================
# Vertex AI Configuration (Optional)
# ========================================
# Only needed if you want to use Vertex AI instead of AI Studio
# Vertex AI has no daily limit but is paid (very cheap: ~$0.00025 per 1000 chars)
# Get from: https://console.cloud.google.com/vertex-ai
USE_VERTEX_AI=false
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# ========================================
# Server Configuration
# ========================================
PORT=8000
